{
  "custom/weather": {
    "exec-if": "which wttrbar",
    "exec": "wttrbar --location Santiago",
    "restart-interval": 300,
    "tooltip": true,
    "format": "{}°",
    "return-type": "json",
    "on-click": "kitty --hold --class center-float zsh -c 'curl wttr.in/Santiago'",
    "on-click-right": "kitty --hold --class center-float zsh -c 'curl wttr.in/Santiago'",
    "on-click-middle": "xdg-open https://wttr.in/Santiago",
  },
}
